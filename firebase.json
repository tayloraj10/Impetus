{
  "firestore": [
    { "database": "(default)", "rules": "firestore.rules" },
    { "database": "impetus-dev", "rules": "firestore.rules" }
  ],
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
