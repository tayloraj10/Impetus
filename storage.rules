rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Users can read/write their own profile photos; anyone can read
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Topic cover images — admin/moderator write, public read
    match /topics/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
          in ['admin', 'moderator'];
    }

    // Group logos — any signed-in user can upload
    match /groups/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Challenge submission proof images — any signed-in user can upload
    match /challenge_submissions/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
