rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isMod() {
      return isAuthed() && userRole() in ['moderator', 'admin'];
    }

    function isAdmin() {
      return isAuthed() && userRole() == 'admin';
    }

    function isOwner(field) {
      return isAuthed() && resource.data[field] == request.auth.uid;
    }

    function noStatusChange() {
      return !('moderationStatus' in request.resource.data.diff(resource.data).affectedKeys());
    }

    function isResubmission() {
      return resource.data.moderationStatus != 'removed'
        && request.resource.data.moderationStatus == 'pending_review';
    }

    function onlyLikesOrFlags() {
      return isAuthed() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'flags']);
    }

    match /topics/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /feed/{id} {
      allow read: if true;
      allow create: if isAuthed() && request.resource.data.submittedBy == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /groups/{id} {
      allow read: if true;
      allow create: if isAuthed();
      allow update: if isMod()
        || onlyLikesOrFlags()
        || (isOwner('submittedBy') && (noStatusChange() || isResubmission()));
      allow delete: if isMod() || isOwner('submittedBy');
    }

    match /resources/{id} {
      allow read: if true;
      allow create: if isAuthed();
      allow update: if isMod()
        || onlyLikesOrFlags()
        || (isOwner('submittedBy') && (noStatusChange() || isResubmission()));
      allow delete: if isMod() || isOwner('submittedBy');
    }

    match /events/{id} {
      allow read: if true;
      allow create: if isAuthed();
      allow update: if isMod()
        || onlyLikesOrFlags()
        || (isOwner('submittedBy') && (noStatusChange() || isResubmission()));
      allow delete: if isMod() || isOwner('submittedBy');
    }

    match /map_pins/{id} {
      allow read: if true;
      allow create: if isAuthed();
      allow update: if isMod()
        || onlyLikesOrFlags()
        || (isOwner('submittedBy') && (noStatusChange() || isResubmission()));
      allow delete: if isMod() || isOwner('submittedBy');
    }

    match /challenges/{id} {
      allow read: if true;
      allow create, update: if isMod();
      allow update: if isAuthed() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantCount']);
      allow delete: if isAdmin();
    }

    match /challenge_submissions/{id} {
      allow read: if true;
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isOwner('userId');
    }

    match /topic_suggestions/{id} {
      allow create: if isAuthed() && request.resource.data.suggestedBy == request.auth.uid;
      allow read, update, delete: if isMod();
    }

    match /users/{userId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.auth.uid == userId;
      allow update: if (isAuthed() && request.auth.uid == userId &&
        !('role' in request.resource.data.diff(resource.data).affectedKeys()))
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /definitions/{docId} {
      allow read: if true;
      allow create: if isAdmin() ||
        (isAuthed() &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.status == 'pending_approval');
      allow delete: if isAdmin();
      allow update: if isMod() ||
        (isAuthed() && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['ratingSum', 'ratingCount', 'updatedAt']));
    }

    match /definition_ratings/{ratingId} {
      allow read: if isAuthed() &&
        (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isAuthed() &&
        request.resource.data.userId == request.auth.uid;
    }
  }
}
